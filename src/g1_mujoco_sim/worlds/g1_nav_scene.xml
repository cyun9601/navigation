<mujoco model="g1_nav_scene">
  <!-- Navigation scene for G1: flat ground + box/cylinder obstacles.
       The robot is included from g1_29dof.xml and driven kinematically
       (planar base) by g1_sim_node. Two mocap bodies carry the LiDAR site
       and the RGBD camera; the sim node sets their poses every tick so the
       sensors track the moving base. -->

  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.8" extent="3.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20" offwidth="1280" offheight="720"/>
    <map znear="0.05" zfar="50"/>
    <quality shadowsize="2048"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.1"/>
    <material name="obstacle" rgba="0.75 0.35 0.2 1"/>
    <material name="wall" rgba="0.55 0.55 0.6 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"
          conaffinity="1" contype="1"/>

    <!-- ===== Obstacles (static). Robot starts near origin facing +x. ===== -->
    <geom name="obs_box_1"  type="box"      material="obstacle" pos="2.0  0.6 0.4"  size="0.3 0.3 0.4"/>
    <geom name="obs_box_2"  type="box"      material="obstacle" pos="2.5 -1.2 0.3"  size="0.4 0.4 0.3"/>
    <geom name="obs_cyl_1"  type="cylinder" material="obstacle" pos="3.6  0.0 0.5"  size="0.35 0.5"/>
    <geom name="obs_box_3"  type="box"      material="obstacle" pos="4.8  1.3 0.5"  size="0.5 0.3 0.5"/>
    <geom name="obs_cyl_2"  type="cylinder" material="obstacle" pos="5.0 -1.0 0.4"  size="0.3 0.4"/>
    <geom name="obs_box_4"  type="box"      material="obstacle" pos="6.2  0.2 0.45" size="0.35 0.6 0.45"/>

    <!-- Boundary walls (~8m x 8m arena centred ahead of the robot) -->
    <geom name="wall_n" type="box" material="wall" pos="3.5  4.0 0.5" size="4.0 0.1 0.5"/>
    <geom name="wall_s" type="box" material="wall" pos="3.5 -4.0 0.5" size="4.0 0.1 0.5"/>
    <geom name="wall_e" type="box" material="wall" pos="7.5  0.0 0.5" size="0.1 4.0 0.5"/>
    <geom name="wall_w" type="box" material="wall" pos="-0.5 0.0 0.5" size="0.1 4.0 0.5"/>

    <!-- ===== Sensor mounts (mocap, pose set by sim node each tick) ===== -->
    <body name="lidar_mount" mocap="true" pos="0 0 1.25">
      <geom name="lidar_marker" type="cylinder" size="0.045 0.02" rgba="0.1 0.1 0.1 1"
            contype="0" conaffinity="0" group="2"/>
      <site name="lidar_site" size="0.02" rgba="1 0 0 1"/>
    </body>

    <body name="camera_mount" mocap="true" pos="0.1 0 1.25">
      <!-- No visual marker geom: the camera view is shown in a separate window
           (cv2) by the sim node instead of being drawn in the 3D scene. -->
      <!-- MuJoCo camera looks along its own -z with +y up; xyaxes maps it so the
           view direction = mount +x (forward) and up = mount +z, matching the
           URDF camera_link convention. The 47.6deg downward pitch (official
           Unitree G1 D435 mount) is baked into the mount pose by the sim node
           (and into the URDF camera_joint). -->
      <camera name="rgbd_cam" mode="fixed" xyaxes="0 -1 0  0 0 1" fovy="58"/>
    </body>
  </worldbody>
</mujoco>
